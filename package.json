{
  "name": "fitquest-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "start:usb": "set EXPO_PACKAGER_HOSTNAME=127.0.0.1 && expo start --lan --port 8083 --clear",
    "open:usb": "powershell -ExecutionPolicy Bypass -File .\\scripts\\open-phone.ps1 -Port 8083",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "expo": "~52.0.25",
    "expo-av": "~15.0.1",
    "expo-speech": "~13.0.0",
    "expo-video": "~2.0.1",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "babel-preset-expo": "~12.0.0"
  }
}
